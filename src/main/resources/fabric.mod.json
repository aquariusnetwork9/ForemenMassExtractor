{
  "schemaVersion": 1,
  "id": "foreman-massextractor",
  "version": "${version}",
  "name": "Foreman MassExtractor",
  "description": "AFK bulk single-block miner for anarchy servers — Baritone-driven mining with shulker/ender-chest storage and pickaxe restock.",
  "authors": [
    "Shallowplague"
  ],
  "contact": {
    "sources": "https://github.com/aquariusnetwork9/foreman-massextractor"
  },
  "icon": "assets/foreman-massextractor/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.shallowplague.foreman.ForemanAddon"
    ]
  },
  "mixins": [
    "foreman-massextractor.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
